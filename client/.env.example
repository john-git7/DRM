# Backend API base URL — override for non-local deployments
VITE_API_BASE=http://localhost:5000/api

# Localhost proctoring agent (Phase 3) the player polls before playback
VITE_AGENT_BASE=http://localhost:7891

# Set to 1 to enforce the recorder-detection gate on Android via the companion
# APK (see agent-android/). Leave unset to keep Android on forensic-watermark-only
# playback so viewers without the APK are not blocked. iOS is never gated.
VITE_ANDROID_AGENT=0

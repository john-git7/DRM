# Runtime content — never commit raw uploads, encrypted HLS output, decryption keys,
# local enrollment data, or audit logs
uploads/
streams/
server/data/videos.json
server/data/keys.json
server/data/enrollments.json
server/data/audit-log.json

# Dependencies / build output (root dev-runner + workspaces)
node_modules/
/node_modules/
dist/
# Project standardizes on pnpm; ignore npm lockfiles
package-lock.json

# TypeScript incremental build info
*.tsbuildinfo

# Python bytecode (agent)
__pycache__/
*.pyc

# Agent build artifacts
agent/dist/
agent/build/
agent-go/dist/
*.deb

# Capacitor — generated native projects (regenerate with `cap add android|ios`).
# Un-ignore and commit these once you customize the native side (manifest, signing).
client/android/
client/ios/
.capacitor/

# Env — private repo: server/.env is committed for convenience (TEST values only).
# Real deployments MUST replace JWT_SECRET/STREAM_SECRET/ADMIN_PASSWORD and keep them
# out of git. keys.json / enrollments / audit / videos stay ignored (live secrets/state).
